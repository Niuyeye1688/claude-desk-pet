  "description": "Claude Code Desktop Pet",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/run.js vite",
    "build": "node scripts/run.js tsc && node scripts/run.js vite build && node scripts/run.js electron-builder",
    "build:win": "node scripts/run.js tsc && node scripts/run.js vite build && node scripts/run.js electron-builder --win",
    "preview": "node scripts/run.js vite preview",
    "postinstall": "electron-builder install-app-deps"
 },
